{
  "name": "@iterumarchive/neo-calendar-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -Apt run build",
    "clean": "yarn workspaces foreach -Ap run clean && rm -rf dist",
    "rebuild": "yarn clean && yarn build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "verify:drift": "tsx src/scripts/verify-zero-drift.ts",
    "verify:drift-advanced": "tsx src/scripts/verify-zero-drift-advanced.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "yarn build && changeset publish",
    "release:check": "./scripts/pre-publish-check.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.13.0"
}
