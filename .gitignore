# Dependencies
node_modules/
packages/*/node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo
packages/*/dist/
packages/*/build/
packages/*/*.tsbuildinfo

# Prevent build artifacts in source directories
src/**/*.js
src/**/*.d.ts
src/**/*.js.map
src/**/*.d.ts.map
!src/**/*.test.js
!src/**/*.spec.js

# Test coverage
coverage/

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
